{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ROCm Forge",
  "version": "0.1.0",
  "identifier": "com.rocmforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ROCm Forge",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0a0c",
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* https://huggingface.co https://*.huggingface.co https://ollama.com http://localhost:11434"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
